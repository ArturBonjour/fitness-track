# MongoDB connection string
# For local development: mongodb://127.0.0.1:27017/fitness-tracker
# For Docker: mongodb://mongo:27017/fitness-tracker (set automatically by docker-compose)
MONGO_URI=mongodb://127.0.0.1:27017/fitness-tracker

# JWT secret — replace with a long random string in production
# Example: openssl rand -hex 32
JWT_SECRET=change_me_in_production

# Server port (default 5001)
PORT=5001
